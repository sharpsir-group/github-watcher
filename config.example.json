{
  "repos": {
    "your-org/your-app": {
      "name": "My App",
      "localPath": "/home/deploy/your-app",
      "deployPath": "/var/www/your-app",
      "branch": "main",
      "preBuild": [
        {
          "file": "vite.config.ts",
          "find": "export default defineConfig({",
          "replace": "export default defineConfig({\n  base: \"/app/\","
        },
        {
          "file": "src/App.tsx",
          "find": "<BrowserRouter>",
          "replace": "<BrowserRouter basename=\"/app\">"
        },
        {
          "file": "src/lib/matrix-sso.ts",
          "find": "const BASE_PATH = '/matrix-apps-template'",
          "replace": "const BASE_PATH = '/app'"
        }
      ],
      "buildCmd": "npm install --include=dev && npm run build",
      "distFolder": "dist",
      "postDeploy": [],
      "cloudfront": {
        "distributionId": "E1XXXXXXXXXX",
        "invalidationPaths": ["/*"]
      },
      "cloudflare": {
        "zoneId": "your-zone-id",
        "purgeEverything": true,
        "apiTokenKey": "CF_API_TOKEN"
      },
      "secret": "WEBHOOK_SECRET_MY_APP"
    },
    "your-org/api-service": {
      "name": "API Service",
      "localPath": "/home/deploy/api-service",
      "deployPath": "/var/www/api",
      "branch": "production",
      "preBuild": [],
      "buildCmd": "npm ci && npm run build",
      "distFolder": "build",
      "postDeploy": ["pm2 restart api-service"],
      "cloudfront": {},
      "secret": "WEBHOOK_SECRET_API"
    }
  }
}
