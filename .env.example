# GitHub Watcher Environment
# Copy to .env and fill in your values:  cp .env.example .env && chmod 600 .env

# --- Webhook Secrets (referenced by config.json "secret" field) ---
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET_MY_APP=

# --- AWS (optional — CloudFront cache invalidation) ---
# IAM permissions: cloudfront:CreateInvalidation
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- Cloudflare (optional — edge + Worker cache purge) ---
# Token permissions: Zone > Cache Purge > Purge
CF_API_TOKEN=
