{
  "repos": {
    "sharpsir-group/itsm-2-1": {
      "name": "ITSM",
      "localPath": "/home/bitnami/itsm-2-1",
      "deployPath": "/opt/bitnami/apache/htdocs/itsm",
      "branch": "main",
      "preBuild": [
        {
          "file": "vite.config.ts",
          "find": "\\n\\s*base:\\s*['\"][^'\"]*['\"],?",
          "replace": "",
          "regex": true
        },
        {
          "file": "vite.config.ts",
          "find": "export default defineConfig(({ mode }) => ({",
          "replace": "export default defineConfig(({ mode }) => ({\n  base: \"/itsm/\","
        },
        {
          "file": "src/App.tsx",
          "find": "<BrowserRouter(\\s+basename=\"[^\"]*\")?>",
          "replace": "<BrowserRouter basename=\"/itsm\">",
          "regex": true
        },
        {
          "file": "src/lib/matrix-sso.ts",
          "find": "const BASE_PATH = '[^']*'",
          "replace": "const BASE_PATH = '/itsm'",
          "regex": true
        }
      ],
      "buildCmd": "npm install --include=dev && npm run build",
      "distFolder": "dist",
      "postDeploy": [],
      "cloudfront": {},
      "secret": "WEBHOOK_SECRET_ITSM"
    },
